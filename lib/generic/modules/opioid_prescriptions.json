      "duration": {
        "low": 1,
        "high": 2,
        "unit": "hours"
      },
      "codes": [
        {
          "system": "CPT",
          "code": "72158",
          "display": "Diagnostic Radiology (Diagnostic Imaging) Procedures of the Spine and Pelvis"
